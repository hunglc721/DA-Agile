<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /DA1-10-main/

    # Allow direct access to existing files and directories
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Route everything to index.php (including root)
    RewriteRule ^(.*)$ /DA1-10-main/index.php?action=$1 [QSA,L]
</IfModule>
